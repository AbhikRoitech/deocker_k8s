# Root env file for Docker Compose. Copy to .env: `cp .env.example .env`
# Compose auto-loads .env and substitutes ${VAR} in docker-compose.yml.
# .env is git-ignored — never commit real credentials.

# --- Postgres container (postgres:16-alpine) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=appdb

# --- Values the API (server) reads; must match the Postgres settings above ---
PGDATABASE=appdb
PGUSER=postgres
PGPASSWORD=postgres
